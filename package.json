{
  "name": "@slashgear/roadmap-maker",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:team": "VITE_APP_MODE=team vite build --outDir ../public-team",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "lint": "oxlint client",
    "lint:fix": "oxlint --fix client",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "server": "bun run server/index.ts",
    "server:team": "STORAGE=postgres bun run server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build:team && playwright test",
    "test:e2e:ui": "bun run build:team && playwright test --ui",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@hono/swagger-ui": "^0.6.0",
    "hono": "^4.12.5",
    "html-to-image": "^1.11.13",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.8",
    "preact": "^10.28.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.3",
    "autoprefixer": "^10.4.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.4.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
