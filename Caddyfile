:8080 {
	root * /srv
	# Serve pre-compressed files produced in the Docker build step
	# (zstd → .zst, brotli → .br, gzip → .gz — Caddy picks the best match per Accept-Encoding)
	file_server {
		precompressed zstd br gzip
	}

	# Aggressive cache for versioned assets (Vite adds a content hash to filenames)
	@assets path *.js *.css *.woff2 *.woff *.ico *.svg *.png *.webp
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# No cache for index.html (always revalidated)
	header /index.html Cache-Control "no-cache, must-revalidate"

	# Security headers
	header {
		X-Content-Type-Options     "nosniff"
		X-Frame-Options            "DENY"
		X-XSS-Protection           "1; mode=block"
		Referrer-Policy            "strict-origin-when-cross-origin"
		Permissions-Policy         "geolocation=(), microphone=(), camera=()"

		# CSP — tailored to the stack:
		#   script-src 'self'          → Vite bundle only, no external CDN
		#   style-src 'unsafe-inline'  → JSX inline styles (style={{}}) + Vite-injected CSS
		#   font-src 'self'            → @fontsource fonts bundled locally by Vite
		#   img-src 'self' data:       → no external images; data: for potential inline SVGs
		#   connect-src 'self'         → no external API calls (all data in localStorage)
		#   frame-ancestors 'none'     → modern equivalent of X-Frame-Options DENY
		Content-Security-Policy    "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

		-Server
	}
}
